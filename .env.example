# ============================================================================
# BLACK BELT PLATFORM - CONFIGURACAO DE AMBIENTE
# ============================================================================
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env com credenciais reais

# ============================================================================
# BANCO DE DADOS - MySQL (XAMPP)
# ============================================================================
DATABASE_URL=mysql://root:@localhost:3306/blackbelt

# ============================================================================
# SERVIDOR
# ============================================================================
NODE_ENV=development
PORT=5000

# ============================================================================
# SEGURANCA
# ============================================================================
# Gere uma chave segura com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
COOKIE_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING

# ============================================================================
# FRONTEND URL (para CORS)
# ============================================================================
FRONTEND_URL=http://localhost:5000

# ============================================================================
# PAGAMENTO: Asaas
# ============================================================================
# Crie uma conta em https://www.asaas.com e obtenha sua API key
# Sandbox: https://sandbox.asaas.com
# ASAAS_API_KEY=sk_prod_...
# ASAAS_WEBHOOK_TOKEN=seu_token_secreto
# ASAAS_SANDBOX=false

# ============================================================================
# OPCIONAL: Email (SMTP)
# ============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASSWORD=sua-senha-app
# SMTP_FROM=noreply@blackbelt.com

# ============================================================================
# OPCIONAL: Monitoramento (Sentry)
# ============================================================================
# Crie um projeto em https://sentry.io e copie o DSN
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ============================================================================
# OPCIONAL: Logging
# ============================================================================
# LOG_LEVEL=info

# ============================================================================
# OPCIONAL: AWS S3 (Upload de arquivos)
# ============================================================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=sa-east-1
# AWS_S3_BUCKET=blackbelt-uploads

# ============================================================================
# OPCIONAL: Webhook Secret (para integrações externas)
# ============================================================================
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WEBHOOK_SECRET=

# ============================================================================
# OPCIONAL: CORS - Origens adicionais (separadas por vírgula)
# ============================================================================
# ALLOWED_ORIGINS=https://app.blackbelt.com,https://admin.blackbelt.com

# ============================================================================
# OPCIONAL: Certificado Digital A1 (ICP-Brasil) para assinatura de PDFs
# ============================================================================
# A1_CERT_PATH=/opt/blackbelt/server/certs/blackbelt-a1.p12
# A1_CERT_PASSWORD=sua_senha_aqui
